# AgentOS reference runtime defaults. Production packages use Unix sockets.
AGENTOS_STATE_DIR=/var/lib/agentos
AGENTOS_LISTEN_HOST=127.0.0.1
AGENTOS_LISTEN_PORT=7788
AGENTOS_CONFIG_FILE=/etc/agentos/config.json
AGENTOS_PROVIDERS_FILE=/etc/agentos/providers.json
AGENTOS_SECRETS_FILE=/etc/agentos/secrets.json

# Optional ordered provider:model fallbacks. No route is enabled by default.
# AGENTOS_GATEWAY_FALLBACKS=

# Set this in a root-readable systemd credential or protected environment file
# to require Bearer authentication on all endpoints except /v1/health.
# AGENTOS_API_TOKEN=

# Secrets are loaded into the gateway service only.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
