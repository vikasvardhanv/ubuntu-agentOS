#!/bin/sh
set -eu

STATE_DIR="${AGENTOS_STATE_DIR:-/var/lib/agentos}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/agentos"

printf '\nAgentOS first-boot setup\n\n'
cd /usr/lib/agentos
sudo /usr/bin/python3 -m agentos.onboarding

printf '\nMemory mode (local/enterprise) [local]: '
read -r memory
memory="${memory:-local}"

printf 'Approval policy (strict/balanced) [strict]: '
read -r approval
approval="${approval:-strict}"

install -d -m 0700 "$CONFIG_DIR"
umask 077
cat > "$CONFIG_DIR/config.json" <<EOF
{"memory_mode":"$memory","approval_policy":"$approval"}
EOF

sudo chown root:agentos /etc/agentos/providers.json /etc/agentos/secrets.json
sudo chmod 0640 /etc/agentos/providers.json /etc/agentos/secrets.json
sudo systemctl restart agentos-runtime.service
printf '\nAgentOS setup complete. Your selected provider is available through model="auto".\n'

sudo touch "$STATE_DIR/onboarding-complete"
sudo rm -f /etc/xdg/autostart/agentos-onboarding.desktop
